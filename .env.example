# Headless Oracle — environment configuration
#
# Copy to .env and fill in values. Never commit .env to git.
#
# API key (optional — sandbox key is auto-provisioned if not set):
#   Free:    headlessoracle.com  → click "Get sandbox key"
#   Paid:    headlessoracle.com/pricing
#   x402:    See examples/04-x402-autopay/ to have your agent mint its own key
#
HEADLESS_ORACLE_API_KEY=

# Exchange to check (default: XNYS — NYSE)
# Full list: https://api.headlessoracle.com/v5/exchanges
MIC=XNYS

# For example 04 (x402 autonomous payment) only:
# Base mainnet wallet private key — agent uses this to pay for its own Oracle access
# Wallet needs ~0.001 USDC + ~0.001 ETH on Base mainnet
# DO NOT commit this key. DO NOT use your main wallet — use a dedicated agent wallet.
AGENT_WALLET_PRIVATE_KEY=
